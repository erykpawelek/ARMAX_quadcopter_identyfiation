<?xml version="1.0" ?>
<sdf version="1.9">

  <!-- Main frame of the model-->
  <model name="dropper_drone">
    <pose>0 0 0 0 0 0</pose>
    <link name="base_link">

      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>1000</update_rate>
      </sensor>

      <inertial>
        <mass>1.410</mass>
        <pose>-0.002060 -0.001083 0.034620 0 0 0</pose>
        <inertia>
          <ixx>0.0034</ixx>
          <iyy>0.0043</iyy>
          <izz>0.0055</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      
      <visual name="base_link_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh><uri>../01_mechanics/CAD/Drone_assembly_gazebo.obj</uri></mesh>
        </geometry>
      </visual>
      
      <collision name="bottom_plate_collision">
        <pose>0.0 0.0 0.01 0 0 0</pose>
        <geometry>
          <box>
            <size>0.185 0.185 0.02</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="electronics_compartment_collision">
        <pose>0 0 0.017 0 0 0</pose>
        <geometry>
          <box>
            <size>0.12 0.055 0.024</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="battery_collision">
        <pose>0 0 0.048 0 0 0</pose>
        <geometry>
          <box>
            <size>0.078 0.038 0.038</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="motor0_collision">
        <pose>0.088388 -0.088388 0.0137065 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.027</radius>
            <length>0.017</length>
          </cylinder>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="motor1_collision">
        <pose>-0.088388 0.088388 0.0137065 0 0 0</pose>
        <geometry>
          <cylinder>

      <collision name="motor2_collision">
        <pose>0.088388 0.088388 0.0137065 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.027</radius>
            <length>0.017</length>
          </cylinder>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>

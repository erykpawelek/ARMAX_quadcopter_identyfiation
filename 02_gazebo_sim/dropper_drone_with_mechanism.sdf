      <collision name="motor3_collision">
        <pose>-0.088388 -0.088388 0.0137065 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.027</radius>
            <length>0.017</length>
          </cylinder>
        </geometry>
        <surface>
          <contact>
            <ode>
              <max_vel>100.0</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

    </link>

    <link name="rotor_0">
      <pose>0.088388 -0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_0_visual">
        <geometry><mesh><uri>../01_mechanics/CAD/CCW_propeller.obj</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><damping>0.0002</damping><friction>0.0002</friction></dynamics>
      </axis>
    </joint>

    <link name="rotor_1">
      <pose>-0.088388 0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>

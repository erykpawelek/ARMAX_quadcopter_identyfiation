        <dynamics><damping>0.0002</damping><friction>0.0002</friction></dynamics>
      </axis>
    </joint>
    
    <link name="rotor_3">
      <pose>-0.088388 -0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_3_visual">
        <geometry><mesh><uri>../01_mechanics/CAD/CW_propeller.obj</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><damping>0.0002</damping><friction>0.0002</friction></dynamics>
      </axis>
    </joint>

    <model name="payload_model">
      <link name="payload_link">
        <pose>0 0 -0.06 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <pose>0 0 0 0 0 0</pose>
          <inertia>
            <ixx>0.000208</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.000208</iyy>
            <iyz>0</iyz>
            <izz>0.000208</izz>
          </inertia>
        </inertial>
        <visual name="payload_visual">
          <geometry>
            <box>
              <size>0.05 0.05 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>1.00 0.35 0.00 1.0</ambient>
            <diffuse>1.00 0.35 0.00 1.0</diffuse>
          </material>
        </visual>
        <collision name="payload_collision">
          <geometry>
            <box>
              <size>0.05 0.05 0.05</size>
            </box>
          </geometry>
        </collision>
      </link>
    </model>

    <plugin filename="gz-sim-detachable-joint-system" name="gz::sim::systems::DetachableJoint">
      <parent_link>base_link</parent_link>
      <child_model>payload_model</child_model>
      <child_link>payload_link</child_link>
      <detach_topic>/payload/detach</detach_topic>
    </plugin>
    
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"></plugin>

    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.35</a0>
      <alpha_stall>1.5</alpha_stall>
      <cla>1.03</cla>
      <cda>0.025</cda>
      <cma>0.0</cma>
      <cla_stall>-0.1</cla_stall>
      <cda_stall>0.15</cda_stall>
      <cma_stall>0.0</cma_stall>
      <area>0.0008</area>
      <air_density>1.2041</air_density>
      <cp>0.045 0 0</cp>
      <forward>0 1 0</forward> 
      <upward>0 0 1</upward>
      <link_name>rotor_0</link_name>
    </plugin>
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
     <a0>0.35</a0>
      <alpha_stall>1.5</alpha_stall>
